# PostgreSQL (required). On Railway, link a Postgres service — DATABASE_URL is injected automatically.
# Local example:
# DATABASE_URL=postgresql://user:password@127.0.0.1:5432/yap_to_context
DATABASE_URL=

# OpenAI (required). Set as a Railway service variable; used for transcription + extraction.
OPENAI_API_KEY=

# App password (required in production). Single sign-in secret — what you type to log in
# AND what every API request sends as `Authorization: Bearer <AUTH_SECRET>`.
AUTH_SECRET=

# Audio file storage (not in Postgres). Local default: ./storage/audio
# On Railway, mount a volume or set to a persistent path, e.g. /data/audio
AUDIO_STORAGE_PATH=
